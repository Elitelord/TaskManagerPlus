{
  "$schema": "https://raw.githubusercontent.com/nicell/tauri-apps-tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "TaskManagerPlus",
  "version": "1.0.1",
  "identifier": "com.taskmanagerplus.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TaskManagerPlus",
        "width": 1100,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../native/build/Release/taskmanager_native.dll": "taskmanager_native.dll"
    },
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE3NkJDMzgyNUE4MkQ3MDkKUldRSjE0SmFnc05yRjVadyt1OW94OVl4YjRqNGdJOWc3SVhmUzlpRHU2RDFqVG1nUzRMbUxqeHEK",
      "endpoints": [
        "https://github.com/Elitelord/TaskManagerPlus/releases/latest/download/latest.json"
      ]
    }
  }
}
