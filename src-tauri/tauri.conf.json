{
  "$schema": "https://raw.githubusercontent.com/nicell/tauri-apps-tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "TaskManagerPlus",
  "version": "0.1.0",
  "identifier": "com.taskmanagerplus.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TaskManagerPlus",
        "width": 1100,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../native/build/Release/taskmanager_native.dll"]
  }
}
